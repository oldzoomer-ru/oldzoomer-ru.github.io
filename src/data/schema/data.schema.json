{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Site and CV Data Schema",
  "description": "Schema for combined site and CV data",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "config": {
      "type": "object",
      "properties": {
        "site": {
          "type": "object",
          "properties": {
            "domain": { "type": "string" },
            "baseUrl": { "type": "string", "format": "uri" },
            "title": { "type": "string" },
            "ogSiteName": { "type": "string" },
            "locale": { "type": "string" },
            "description": { "type": "string" },
            "author": { "type": "string" },
            "language": { "type": "string" }
          },
          "required": ["domain", "baseUrl", "title", "description", "author", "language"]
        },
        "deployment": {
          "type": "object",
          "properties": {
            "githubRepo": { "type": "string" },
            "githubBaseUrl": { "type": "string", "format": "uri" }
          },
          "required": ["githubRepo", "githubBaseUrl"]
        }
      },
      "required": ["site", "deployment"]
    },
    "person": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "jobTitle": { "type": "string" },
        "email": { "type": "string" },
        "description": { "type": "string" },
        "sameAs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knowsAbout": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "jobTitle", "email", "description", "sameAs", "knowsAbout"]
    },
    "cv": {
      "type": "object",
      "properties": {
        "personal": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "telegram": { "type": "string" },
            "setka": { "type": "string" },
            "github": { "type": "string" },
            "website": { "type": "string" },
            "location": { "type": "string" },
            "citizenship": { "type": "string" }
          },
          "required": ["name"]
        },
        "desiredPosition": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "specializations": {
              "type": "array",
              "items": { "type": "string" }
            },
            "employmentType": {
              "type": "array",
              "items": { "type": "string" }
            },
            "workFormat": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["title"]
        },
        "summary": { "type": "string" },
        "experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "position": { "type": "string" },
              "company": { "type": "string" },
              "location": { "type": "string" },
              "startDate": { "type": "string" },
              "endDate": { "type": "string" },
              "description": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["position", "company", "startDate", "description"]
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "institution": { "type": "string" },
              "location": { "type": "string" },
              "degree": { "type": "string" },
              "field": { "type": "string" },
              "graduationYearStart": { "type": "integer", "minimum": 1900, "maximum": 2100 },
              "graduationYearEnd": { "type": "integer", "minimum": 1900, "maximum": 2100 }
            },
            "required": ["institution", "degree"]
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "codeRepository": { "type": "string" },
              "programmingLanguage": { "type": "string" }
            },
            "required": ["name", "description", "codeRepository", "programmingLanguage"]
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
              "level": { "type": "string" }
            },
            "required": ["language", "level"]
          }
        },
        "skills": {
          "type": "object",
          "properties": {
            "technical": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["technical"]
        }
      },
      "required": ["personal", "desiredPosition", "skills"]
    }
  },
  "required": ["config", "person", "cv"]
}